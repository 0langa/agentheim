# Provider registry (provider-agnostic)
AI_TEAM_PROVIDER_IDS=default
AI_TEAM_PROVIDER_DEFAULT_TYPE=openai_compatible
AI_TEAM_PROVIDER_DEFAULT_ENDPOINT=https://your-openai-compatible-endpoint/v1
AI_TEAM_PROVIDER_DEFAULT_API_KEY_ENV=AI_TEAM_DEFAULT_API_KEY
AI_TEAM_DEFAULT_API_KEY=replace-with-api-key
AI_TEAM_PROVIDER_DEFAULT_TIMEOUT_SECONDS=60
# AI_TEAM_PROVIDER_DEFAULT_HEADERS_JSON={"x-tenant":"demo"}

# Model registry (logical workflow roles)
AI_TEAM_MODEL_PLANNER_PROVIDER=default
AI_TEAM_MODEL_PLANNER_NAME=grok-4-20-reasoning
AI_TEAM_MODEL_EXECUTOR_PROVIDER=default
AI_TEAM_MODEL_EXECUTOR_NAME=grok-4-1-fast-reasoning
AI_TEAM_MODEL_VERIFIER_PROVIDER=default
AI_TEAM_MODEL_VERIFIER_NAME=grok-4-20-non-reasoning

# Optional capability layers (disabled by default)
AI_TEAM_ENABLE_GITHUB=false
AI_TEAM_ENABLE_MCP=false
AI_TEAM_ENABLE_WEB=false

# Deprecated legacy compatibility (optional, not recommended):
# GROK_ORCHESTRATOR_ENDPOINT=...
# GROK_ORCHESTRATOR_KEY=...
# GROK_ORCHESTRATOR_MODEL=...
# GROK_CODER_ENDPOINT=...
# GROK_CODER_KEY=...
# GROK_CODER_MODEL=...
# GROK_VERIFIER_ENDPOINT=...
# GROK_VERIFIER_KEY=...
# GROK_VERIFIER_MODEL=...
