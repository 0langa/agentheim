GROK_ORCHESTRATOR_PROVIDER=azure_foundry
GROK_ORCHESTRATOR_ENDPOINT=https://your-resource.services.ai.azure.com
GROK_ORCHESTRATOR_KEY=replace-with-orchestrator-key
GROK_ORCHESTRATOR_MODEL=grok-4-20-reasoning

GROK_CODER_PROVIDER=azure_foundry
GROK_CODER_ENDPOINT=https://your-resource.services.ai.azure.com
GROK_CODER_KEY=replace-with-coder-key
GROK_CODER_MODEL=grok-4-1-fast-reasoning

GROK_VERIFIER_PROVIDER=azure_foundry
GROK_VERIFIER_ENDPOINT=https://your-resource.services.ai.azure.com
GROK_VERIFIER_KEY=replace-with-verifier-key
GROK_VERIFIER_MODEL=grok-4-20-non-reasoning

# Optional capability layers (disabled by default)
AI_TEAM_ENABLE_GITHUB=false
AI_TEAM_ENABLE_MCP=false
AI_TEAM_ENABLE_WEB=false

# Legacy aliases also supported by loader:
# AZURE_GROK_ENDPOINT=...
# AZURE_GROK_KEY=...
# AZURE_GROK_MODEL=grok-4-20-reasoning
# GROK_REASONER_ENDPOINT=...
# GROK_REASONER_KEY=...
# GROK_REASONER_MODEL=grok-4-20-reasoning
# GROK_VERIFY_ENDPOINT=...
# GROK_VERIFY_KEY=...
# GROK_VERIFY_MODEL=grok-4-20-non-reasoning
